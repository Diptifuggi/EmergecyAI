APP_NAME=EmergencyIQ API
ENVIRONMENT=dev
DATABASE_URL=postgresql+psycopg2://user:1234@localhost:5432/emergencyiq_db
# DATABASE_URL=postgresql+asyncpg://user:1234@localhost:5432/emergencyiq
SECRET_KEY=replace-with-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_UPLOAD_SIZE_MB=10
ALLOWED_AUDIO_EXTENSIONS=wav,mp3,m4a,ogg
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
