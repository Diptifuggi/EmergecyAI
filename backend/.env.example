APP_NAME=EmergencyIQ
ENVIRONMENT=development

# AsyncPG connection URL format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/emergencyiq_db

SECRET_KEY=replace-with-a-secure-random-string

ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

MAX_UPLOAD_SIZE_MB=50

# Comma-separated list (will be parsed by pydantic-settings into a list)
# ALLOWED_AUDIO_EXTENSIONS=["wav","mp3","m4a","ogg"]
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
ALLOWED_AUDIO_EXTENSIONS=wav,mp3,m4a,ogg
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

AUDIO_EVENT_DETECTOR_BACKEND=lightweight_fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b